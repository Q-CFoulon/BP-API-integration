# Blackpoint Cyber API Configuration (legacy Node scripts)
BLACKPOINT_API_URL=https://api.blackpointcyber.com
BLACKPOINT_API_KEY=

# Unified backend CompassOne configuration (used by onboarding + BP routes)
COMPASSONE_API_URL=https://api.blackpointcyber.com
COMPASSONE_API_KEY=

# Optional per-tenant secure references used by config/tenants.json
# Example tenant: NONIN
NONIN_BP_CUSTOMER_ID=
NONIN_MS_TENANT_ID=
NONIN_MS_CLIENT_ID=
NONIN_MS_CLIENT_SECRET=

# Do not put Blackpoint API keys in REACT_APP_* variables.
# Frontend calls backend /api endpoints and should not carry provider tokens.
